{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask",
            "type": "python",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "yakdoli-test/app.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--debugger",
                "--host=0.0.0.0",
                "--port=3000"
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "localhost에 대해 Chrome 시작",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/yakdoli-test"
        }
    ]
}